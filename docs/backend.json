
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "institutionId": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "specificGrades": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "trialEndsAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tenantId"]
    },
    "Student": {
      "title": "Student",
      "description": "Comprehensive enterprise student enrollment record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "studentId": { "type": "string" },
        "parentUid": { "type": "string", "description": "UID of the linked parent user account." },
        "firstName": { "type": "string" },
        "middleName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "dateOfBirth": { "type": "string", "format": "date" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "graduated", "withdrawn"] }
      },
      "required": ["tenantId", "firstName", "lastName", "admissionNumber"]
    },
    "ExamRecord": {
      "title": "Exam Record",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "studentId": { "type": "string" },
        "parentUid": { "type": "string" },
        "subjectId": { "type": "string" },
        "examScore": { "type": "number" },
        "classScore": { "type": "number" },
        "totalScore": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/students/{studentId}": { "schema": "Student" },
    "/exam_records/{recordId}": { "schema": "ExamRecord" },
    "/attendance/{attendanceId}": { "description": "Attendance logs" },
    "/student_ledger/{ledgerId}": { "description": "Financial ledger" }
  }
}
