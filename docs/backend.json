
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "institutionId": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "specificGrades": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "trialEndsAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tenantId"]
    },
    "AcademicYear": {
      "title": "Academic Year",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "year": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] }
      },
      "required": ["tenantId", "year"]
    },
    "Term": {
      "title": "Academic Term",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "academicYearId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "upcoming", "completed"] }
      },
      "required": ["tenantId", "academicYearId", "name"]
    },
    "Class": {
      "title": "Classroom Definition",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "gradeLevel": { "type": "string" }
      },
      "required": ["tenantId", "name"]
    },
    "Section": {
      "title": "Class Stream/Section",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "classId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["tenantId", "classId", "name"]
    },
    "Student": {
      "title": "Student",
      "description": "Comprehensive student enrollment record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string" },
        "institutionId": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["tenantId", "firstName", "lastName", "studentId"]
    },
    "Staff": {
      "title": "Staff Member",
      "description": "Institutional employee record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "staffId": { "type": "string" },
        "joiningDate": { "type": "string" },
        "institutionId": { "type": "string" }
      },
      "required": ["tenantId", "fullName", "role"]
    },
    "Subject": {
      "title": "Academic Subject",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "gradeLevels": { "type": "array", "items": { "type": "string" } },
        "institutionId": { "type": "string" }
      },
      "required": ["tenantId", "name"]
    },
    "TeacherAssignment": {
      "title": "Teacher Assignment",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "staffId": { "type": "string" },
        "classId": { "type": "string" },
        "sectionId": { "type": "string" },
        "subjectId": { "type": "string" },
        "academicYearId": { "type": "string" }
      },
      "required": ["tenantId", "staffId", "subjectId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/academic_years/{yearId}": { "schema": "AcademicYear" },
    "/terms/{termId}": { "schema": "Term" },
    "/classes/{classId}": { "schema": "Class" },
    "/sections/{sectionId}": { "schema": "Section" },
    "/students/{studentId}": { "schema": "Student" },
    "/staff/{staffId}": { "schema": "Staff" },
    "/subjects/{subjectId}": { "schema": "Subject" },
    "/teacher_assignments/{assignId}": { "schema": "TeacherAssignment" },
    "/exam_records/{recordId}": { "schema": "ExamRecord" },
    "/approved_fees/{feeId}": { "schema": "FeeItem" },
    "/student_ledger/{ledgerId}": { "schema": "StudentLedgerEntry" },
    "/settings/{settingId}": { "description": "Global institutional settings" },
    "/departments/{departmentId}": { "description": "Institutional department definitions" }
  }
}
