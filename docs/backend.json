
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "owner", "staff", "student"] },
        "institutionId": { "type": "string", "description": "Reference to the school/institution this user belongs to." },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "subscriptionPlan": { "type": "string", "enum": ["basic", "premium", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerEmail"]
    },
    "Student": {
      "title": "Student",
      "description": "Student enrollment record.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "graduated"] },
        "institutionId": { "type": "string" }
      },
      "required": ["firstName", "lastName", "gradeLevel", "institutionId"]
    },
    "Staff": {
      "title": "Staff Member",
      "description": "Institutional employee record.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "institutionId": { "type": "string" }
      },
      "required": ["fullName", "role", "institutionId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles. Super Admins: asareg365@gmail.com, frankyeb@gmail.com. Owners: admin@demo.com."
    },
    "/institutions/{institutionId}": {
      "schema": "Institution",
      "description": "Details for each school instance."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Global student records partitioned by institutionId."
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Global staff records partitioned by institutionId."
    }
  }
}
