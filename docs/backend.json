
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "institutionId": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "specificGrades": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "trialEndsAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tenantId"]
    },
    "Staff": {
      "title": "Staff Record",
      "description": "Comprehensive HR record for school employees.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "staffId": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "accountant", "librarian", "receptionist", "cleaner", "security", "ict", "headmaster", "administrator"] },
        "department": { "type": "string" },
        "qualification": { "type": "string" },
        "salary": { "type": "number" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "ssnitNumber": { "type": "string" },
        "nssfNumber": { "type": "string" },
        "nextOfKinName": { "type": "string" },
        "nextOfKinPhone": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "joiningDate": { "type": "string", "format": "date" },
        "contractType": { "type": "string", "enum": ["Full-time", "Part-time", "Contract"] },
        "photoUrl": { "type": "string" }
      },
      "required": ["tenantId", "staffId", "fullName", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Comprehensive enterprise student enrollment record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "studentId": { "type": "string" },
        "parentUid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "status": { "type": "string" }
      },
      "required": ["tenantId", "firstName", "lastName", "admissionNumber"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/staff/{staffId}": { "schema": "Staff" },
    "/students/{studentId}": { "schema": "Student" },
    "/exam_records/{recordId}": { "description": "Academic scores" },
    "/attendance/{attendanceId}": { "description": "Presence logs" },
    "/student_ledger/{ledgerId}": { "description": "Fees history" },
    "/settings/{settingId}": { "description": "School settings" },
    "/departments/{departmentId}": { "description": "School departments" }
  }
}
