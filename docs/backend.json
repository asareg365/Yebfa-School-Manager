{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "tenantId"]
    },
    "Student": {
      "title": "Student",
      "description": "Comprehensive student record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "studentId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "parentUid": { "type": "string" }
      },
      "required": ["tenantId", "firstName", "lastName", "admissionNumber"]
    },
    "FeeItem": {
      "title": "Fee Item",
      "description": "Definition of a specific charge (e.g., Tuition, Uniform).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Mandatory", "Optional", "One-time"] }
      },
      "required": ["tenantId", "name", "amount"]
    },
    "Invoice": {
      "title": "Student Invoice",
      "description": "Bill generated for a student for a specific term.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "discount": { "type": "number" },
        "scholarship": { "type": "number" },
        "amountDue": { "type": "number" },
        "status": { "type": "string", "enum": ["Unpaid", "Partial", "Paid"] },
        "term": { "type": "string" },
        "academicYear": { "type": "string" }
      },
      "required": ["tenantId", "studentId", "totalAmount"]
    },
    "Transaction": {
      "title": "Payment Transaction",
      "description": "Record of cash, MoMo, or Card payment.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "studentId": { "type": "string" },
        "invoiceId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "MTN MoMo", "Telecel Cash", "AirtelTigo Money", "Card", "Bank Transfer"] },
        "reference": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "amount", "paymentMethod"]
    },
    "ExpenseVoucher": {
      "title": "Expenditure Voucher",
      "description": "Record of operational spending.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["tenantId", "amount", "category"]
    },
    "PayrollRecord": {
      "title": "Payroll Disbursement",
      "description": "Salary record for a staff member.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "baseSalary": { "type": "number" },
        "allowances": { "type": "number" },
        "deductions": { "type": "number" },
        "netSalary": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Paid"] },
        "month": { "type": "string" },
        "year": { "type": "string" }
      },
      "required": ["tenantId", "staffId", "netSalary"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/students/{studentId}": { "schema": "Student" },
    "/approved_fees/{feeId}": { "schema": "FeeItem" },
    "/invoices/{invoiceId}": { "schema": "Invoice" },
    "/transactions/{txnId}": { "schema": "Transaction" },
    "/expenditure_vouchers/{voucherId}": { "schema": "ExpenseVoucher" },
    "/payroll_records/{payrollId}": { "schema": "PayrollRecord" }
  }
}