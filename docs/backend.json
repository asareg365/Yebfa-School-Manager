
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "owner", "staff", "student"] },
        "institutionId": { "type": "string", "description": "Reference to the school/institution this user belongs to." },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string" },
        "type": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "specificGrades": { "type": "string" },
        "subscriptionPlan": { "type": "string", "enum": ["basic", "premium", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "pending_review", "suspended"] },
        "academicYear": { "type": "string" },
        "currentTerm": { "type": "string" },
        "customDepartments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "ownerEmail"]
    },
    "Student": {
      "title": "Student",
      "description": "Comprehensive student enrollment record.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "graduated"] },
        "institutionId": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "homeAddress": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["firstName", "lastName", "gradeLevel", "institutionId", "studentId"]
    },
    "Staff": {
      "title": "Staff Member",
      "description": "Institutional employee record.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "staffId": { "type": "string" },
        "joiningDate": { "type": "string", "format": "date" },
        "institutionId": { "type": "string" },
        "assignedClasses": { "type": "string" },
        "assignedSubjects": { "type": "string" }
      },
      "required": ["fullName", "role", "institutionId", "staffId"]
    },
    "ExamRecord": {
      "title": "Examination Record",
      "description": "Records of student performance in exams and class assessments.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "subjectId": { "type": "string" },
        "subjectName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "classScore": { "type": "number" },
        "examScore": { "type": "number" },
        "totalScore": { "type": "number" },
        "term": { "type": "string" },
        "academicYear": { "type": "string" },
        "institutionId": { "type": "string" }
      },
      "required": ["studentId", "subjectId", "institutionId"]
    },
    "FeeItem": {
      "title": "Approved Fee Item",
      "description": "Standardized charges like Books, Tuition, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "defaultAmount": { "type": "number" },
        "category": { "type": "string" },
        "institutionId": { "type": "string" }
      }
    },
    "StudentLedgerEntry": {
      "title": "Student Ledger Entry",
      "description": "Individual charges or credits on a student account.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "type": { "type": "string", "enum": ["charge", "payment"] },
        "item": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "institutionId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/institutions/{institutionId}": {
      "schema": "Institution",
      "description": "Details for each school instance."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Global student records."
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Global staff records."
    },
    "/exam_records/{recordId}": {
      "schema": "ExamRecord",
      "description": "Examination scores."
    },
    "/approved_fees/{feeId}": {
      "schema": "FeeItem",
      "description": "Global approved fee list per school."
    },
    "/student_ledger/{ledgerId}": {
      "schema": "StudentLedgerEntry",
      "description": "Individual student account records."
    }
  }
}
