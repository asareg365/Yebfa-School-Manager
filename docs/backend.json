
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tenantId"]
    },
    "Parent": {
      "title": "Parent / Guardian Profile",
      "description": "Consolidated guardian information for one or more students.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "guardianName": { "type": "string" },
        "phone": { "type": "string" },
        "alternativePhone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "occupation": { "type": "string" },
        "gpsAddress": { "type": "string" },
        "relationship": { "type": "string", "enum": ["Father", "Mother", "Guardian"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "guardianName", "phone"]
    },
    "Student": {
      "title": "Student Profile",
      "description": "Complete student record with documents and parent links.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "indexNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "middleName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dateOfBirth": { "type": "string", "format": "date" },
        "bloodGroup": { "type": "string" },
        "nationality": { "type": "string" },
        "religion": { "type": "string" },
        "photoUrl": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "currentClassId": { "type": "string" },
        "sectionId": { "type": "string" },
        "academicYearId": { "type": "string" },
        "house": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "suspended", "alumni"] },
        "parentId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "digitalAddress": { "type": "string" },
            "town": { "type": "string" },
            "district": { "type": "string" },
            "region": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "documents": {
          "type": "object",
          "properties": {
            "birthCertificate": { "type": "string" },
            "passport": { "type": "string" },
            "medicalReport": { "type": "string" },
            "transferLetter": { "type": "string" },
            "beceResults": { "type": "string" }
          }
        },
        "medical": {
          "type": "object",
          "properties": {
            "allergies": { "type": "string" },
            "specialNeeds": { "type": "string" },
            "disability": { "type": "string" },
            "doctor": { "type": "string" }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "firstName", "lastName", "admissionNumber"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/parents/{parentId}": { "schema": "Parent" },
    "/students/{studentId}": { "schema": "Student" }
  }
}
