
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "tenantId"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "An asset owned by the institution.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Furniture", "Computers", "Printers", "Projectors", "Sports Equipment", "Science Lab", "Office Supplies"] },
        "purchaseDate": { "type": "string", "format": "date" },
        "purchasePrice": { "type": "number" },
        "warrantyExpiry": { "type": "string", "format": "date" },
        "condition": { "type": "string", "enum": ["New", "Good", "Fair", "Poor", "Broken"] },
        "depreciationRate": { "type": "number", "description": "Annual percentage" },
        "assignedTo": { "type": "string", "description": "Staff name or Department" },
        "serialNumber": { "type": "string" }
      },
      "required": ["tenantId", "name", "category", "condition"]
    },
    "LibraryBook": {
      "title": "Library Book",
      "description": "A book in the institutional library collection.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "isbn": { "type": "string" },
        "barcode": { "type": "string" },
        "category": { "type": "string" },
        "totalCopies": { "type": "number" },
        "availableCopies": { "type": "number" },
        "shelfLocation": { "type": "string" }
      },
      "required": ["tenantId", "title", "author", "barcode"]
    },
    "LibraryTransaction": {
      "title": "Library Transaction",
      "description": "Record of a book being borrowed or returned.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "borrowerId": { "type": "string" },
        "borrowerName": { "type": "string" },
        "borrowDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "returnDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Borrowed", "Returned", "Overdue"] },
        "fineAmount": { "type": "number" }
      },
      "required": ["tenantId", "bookId", "borrowerId", "borrowDate", "dueDate"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/inventory/{itemId}": { "schema": "InventoryItem" },
    "/library_books/{bookId}": { "schema": "LibraryBook" },
    "/library_transactions/{txnId}": { "schema": "LibraryTransaction" }
  }
}
