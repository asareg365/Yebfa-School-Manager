
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tenantId"]
    },
    "AcademicYear": {
      "title": "Academic Year",
      "description": "Definition of an academic session (e.g. 2026/2027).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "year": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "year", "status"]
    },
    "Term": {
      "title": "Term / Semester",
      "description": "Sub-division of an academic year.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "academicYearId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "academicYearId", "name"]
    },
    "Class": {
      "title": "Class",
      "description": "Definition of a grade level.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "name"]
    },
    "Section": {
      "title": "Section / Stream",
      "description": "Sub-division of a class (e.g. Section A).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "classId": { "type": "string" },
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "classId", "name"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Academic subject definition.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "name"]
    },
    "TeacherAssignment": {
      "title": "Teacher Assignment",
      "description": "Mapping a teacher to a class, section, and subject.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "teacherId": { "type": "string" },
        "classId": { "type": "string" },
        "sectionId": { "type": "string" },
        "subjectId": { "type": "string" },
        "termId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "teacherId", "classId", "subjectId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/academic_years/{id}": { "schema": "AcademicYear" },
    "/terms/{id}": { "schema": "Term" },
    "/classes/{id}": { "schema": "Class" },
    "/sections/{id}": { "schema": "Section" },
    "/subjects/{id}": { "schema": "Subject" },
    "/teacher_assignments/{id}": { "schema": "TeacherAssignment" }
  }
}
