
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tenantId"]
    },
    "Student": {
      "title": "Student Profile",
      "description": "Complete student record with structured nested data.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "indexNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "middleName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dateOfBirth": { "type": "string", "format": "date" },
        "nationality": { "type": "string" },
        "religion": { "type": "string" },
        "photoUrl": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "currentClassId": { "type": "string" },
        "sectionId": { "type": "string" },
        "academicYearId": { "type": "string" },
        "house": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "suspended", "alumni"] },
        "parentId": { "type": "string" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "parentEmail": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "digitalAddress": { "type": "string" },
            "town": { "type": "string" },
            "district": { "type": "string" },
            "region": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "emergencyContact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "relationship": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "medical": {
          "type": "object",
          "properties": {
            "bloodGroup": { "type": "string" },
            "allergies": { "type": "string" },
            "specialNeeds": { "type": "string" },
            "disability": { "type": "string" },
            "doctor": { "type": "string" }
          }
        },
        "previousSchool": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "classCompleted": { "type": "string" },
            "reason": { "type": "string" }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "firstName", "lastName", "admissionNumber"]
    },
    "AcademicYear": {
      "title": "Academic Year",
      "description": "Definition of an academic session (e.g. 2026/2027).",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "year": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "year", "status"]
    },
    "Term": {
      "title": "Term / Semester",
      "description": "Sub-division of an academic year.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "institutionId": { "type": "string" },
        "academicYearId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "institutionId", "academicYearId", "name"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/students/{studentId}": { "schema": "Student" },
    "/academic_years/{id}": { "schema": "AcademicYear" },
    "/terms/{id}": { "schema": "Term" }
  }
}
