
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about users and their roles within the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "school_owner", "administrator", "teacher", "accountant", "librarian", "student", "parent"] },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role", "tenantId"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerUid": { "type": "string" },
        "location": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "tenantId"]
    },
    "HostelRoom": {
      "title": "Hostel Room",
      "description": "A room within a school hostel.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "capacity": { "type": "number" },
        "occupiedBeds": { "type": "number" }
      },
      "required": ["tenantId", "name", "gender", "capacity"]
    },
    "HostelCheckIn": {
      "title": "Hostel Check In",
      "description": "Log of a student checked into a bed.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "bedNumber": { "type": "string" },
        "checkInDate": { "type": "string", "format": "date" },
        "checkOutDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Checked Out"] }
      },
      "required": ["tenantId", "studentId", "roomId", "checkInDate"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Transport vehicle details.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "plateNumber": { "type": "string" },
        "model": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "capacity": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["tenantId", "plateNumber"]
    },
    "TransportRoute": {
      "title": "Transport Route",
      "description": "A bus route for student pick-up/drop-off.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "vehicleId": { "type": "string" },
        "stops": { "type": "array", "items": { "type": "string" } },
        "monthlyFee": { "type": "number" }
      },
      "required": ["tenantId", "name"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "School-wide broadcast messages.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "target": { "type": "string", "enum": ["All", "Teachers", "Parents", "Students"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "title", "content"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/institutions/{institutionId}": { "schema": "Institution" },
    "/hostels/{roomId}": { "schema": "HostelRoom" },
    "/hostel_logs/{logId}": { "schema": "HostelCheckIn" },
    "/vehicles/{vehicleId}": { "schema": "Vehicle" },
    "/routes/{routeId}": { "schema": "TransportRoute" },
    "/announcements/{annId}": { "schema": "Announcement" }
  }
}
