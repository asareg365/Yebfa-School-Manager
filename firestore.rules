rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {


    // ======================
    // AUTH HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }


    function isSuperAdmin() {

      return signedIn()
      &&
      (
        request.auth.uid == "hyd7AluSrDcLBeViOLj9qQKDqt93"
        ||
        request.auth.uid == "wPZw3XHcXpVQ2f9ZkW4KKfkCzYA2"
      );

    }


    function sameTenant(tenantId) {

      return signedIn()
      &&
      request.auth.token.tenantId == tenantId;

    }



    // ======================
    // INSTITUTIONS
    // ======================


    match /institutions/{institutionId} {


      allow read:
      if signedIn();


      allow create:
      if signedIn();


      allow update, delete:
      if signedIn()
      &&
      (
        isSuperAdmin()
        ||
        resource.data.ownerUid == request.auth.uid
      );

    }



    // ======================
    // USERS
    // ======================


    match /users/{userId} {

      allow read, write:
      if signedIn()
      &&
      (
        request.auth.uid == userId
        ||
        isSuperAdmin()
      );

    }



    // ======================
    // SCHOOL DATA
    // ======================


    match /students/{studentId} {

      allow read, write:
      if signedIn();

    }


    match /staff/{staffId} {

      allow read, write:
      if signedIn();

    }


    match /subjects/{subjectId} {

      allow read, write:
      if signedIn();

    }


    match /exam_records/{recordId} {

      allow read, write:
      if signedIn();

    }


    match /attendance/{attendanceId} {

      allow read, write:
      if signedIn();

    }


    match /approved_fees/{feeId} {

      allow read, write:
      if signedIn();

    }


    match /student_ledger/{ledgerId} {

      allow read, write:
      if signedIn();

    }


    match /expenditure_vouchers/{voucherId} {

      allow read, write:
      if signedIn();

    }


    match /payroll_cycles/{cycleId} {

      allow read, write:
      if signedIn();

    }

    match /settings/{settingId} {

      allow create, read, write:
      if signedIn();

    }

    match /departments/{departmentId} {

      allow create, read, write:
      if signedIn();

    }


    // SUPER ADMIN FALLBACK

    match /{document=**} {

      allow read, write:
      if isSuperAdmin();

    }

  }
}
