
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================
    // AUTH HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userTenant() {
      return userProfile().tenantId;
    }

    function userRole() {
      return userProfile().role;
    }

    // ROLE DEFINITIONS
    function isSuperAdmin() { return signedIn() && userRole() == "super_admin"; }
    function isOwner() { return signedIn() && userRole() == "school_owner"; }
    function isAdmin() { return signedIn() && userRole() == "administrator"; }
    function isAccountant() { return signedIn() && userRole() == "accountant"; }
    function isTeacher() { return signedIn() && userRole() == "teacher"; }
    function isParent() { return signedIn() && userRole() == "parent"; }
    function isStaff() { return isOwner() || isAdmin() || isAccountant() || isTeacher(); }

    function belongsToTenant(data) {
      return data.tenantId == userTenant();
    }

    // ======================
    // USERS & PROFILES
    // ======================

    match /users/{userId} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // ======================
    // MULTI-TENANT SCHOOL DATA
    // ======================

    match /students/{studentId} {
      allow read: if signedIn() && (
        isSuperAdmin() || 
        (belongsToTenant(resource.data) && (isStaff() || resource.data.parentUid == request.auth.uid))
      );
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
      allow delete: if isSuperAdmin() || (signedIn() && resource.data.tenantId == userTenant() && isOwner());
    }

    match /staff/{staffId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    match /lesson_plans/{planId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin() || isTeacher())));
    }

    match /academic_tasks/{taskId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin() || isTeacher())));
    }

    match /exam_records/{recordId} {
      allow read: if signedIn() && (
        isSuperAdmin() || 
        (belongsToTenant(resource.data) && (isStaff() || resource.data.parentUid == request.auth.uid))
      );
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin() || isTeacher())));
    }

    match /attendance/{attendanceId} {
      allow read: if signedIn() && (
        isSuperAdmin() || 
        (belongsToTenant(resource.data) && (isStaff() || resource.data.parentUid == request.auth.uid))
      );
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin() || isTeacher())));
    }

    match /student_ledger/{ledgerId} {
      allow read: if signedIn() && (
        isSuperAdmin() || 
        (belongsToTenant(resource.data) && (isStaff() || resource.data.parentUid == request.auth.uid))
      );
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAccountant())));
    }

    match /academic_years/{yearId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    match /terms/{termId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    match /classes/{classId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    match /sections/{sectionId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    match /subjects/{subjectId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    match /teacher_assignments/{assignId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || (belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }

    // INSTITUTIONAL CONFIG
    match /institutions/{institutionId} {
      allow create: if signedIn();
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow update: if signedIn() && (isSuperAdmin() || (belongsToTenant(resource.data) && isOwner()));
    }

    match /settings/{settingId} {
      allow create, read, write: if signedIn() && (isSuperAdmin() || settingId == userTenant());
    }

    match /departments/{departmentId} {
      allow create, read, write: if signedIn() && (isSuperAdmin() || departmentId == userTenant());
    }

    // CATCH ALL
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
