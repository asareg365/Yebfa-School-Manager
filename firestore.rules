
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================
    // AUTH & PROFILE HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userTenant() {
      return userProfile().tenantId;
    }

    function userRole() {
      return userProfile().role;
    }

    // ======================
    // ROLE DEFINITIONS
    // ======================
    
    function isSuperAdmin() { return signedIn() && userRole() == "super_admin"; }
    function isOwner() { return signedIn() && userRole() == "school_owner"; }
    function isAdmin() { return signedIn() && userRole() == "administrator"; }
    function isAccountant() { return signedIn() && userRole() == "accountant"; }
    function isTeacher() { return signedIn() && userRole() == "teacher"; }
    function isParent() { return signedIn() && userRole() == "parent"; }
    function isLibrarian() { return signedIn() && userRole() == "librarian"; }
    
    // ======================
    // TENANT ISOLATION LOGIC
    // ======================

    // Checks if the document belongs to the user's authorized tenant
    function belongsToUserTenant(data) {
      return signedIn() && data.tenantId == userTenant();
    }

    // Validates that a new document or update maintains correct tenant ownership
    function isValidTenantLock() {
      return signedIn() && (
        isSuperAdmin() || 
        (request.resource.data.tenantId == userTenant() && 
        (resource == null || request.resource.data.tenantId == resource.data.tenantId))
      );
    }

    // ======================
    // COLLECTION RULES
    // ======================

    // User Profiles
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if signedIn();
      allow update: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Institutions
    match /institutions/{instId} {
      allow read: if signedIn() && (isSuperAdmin() || instId == userTenant());
      allow write: if isSuperAdmin() || (signedIn() && instId == userTenant() && (isOwner() || isAdmin()));
    }

    // Standard Multi-Tenant Collections Pattern
    // Applies to: students, staff, academic_years, terms, classes, sections, subjects, 
    // assignments, attendance, exams, fees, ledger, payroll, inventory, library, transport
    
    match /{collectionName}/{docId} {
      
      // Role-based Read Access
      allow read: if signedIn() && (
        isSuperAdmin() || 
        belongsToUserTenant(resource.data)
      );

      // Role-based Write Access with Tenant Locking
      allow create: if signedIn() && isValidTenantLock() && (
        isSuperAdmin() || isOwner() || isAdmin() || 
        (collectionName == 'attendance' && isTeacher()) ||
        (collectionName == 'exam_records' && isTeacher()) ||
        ((collectionName == 'expenditure_vouchers' || collectionName == 'transactions') && isAccountant())
      );

      allow update: if signedIn() && isValidTenantLock() && (
        isSuperAdmin() || isOwner() || isAdmin() || 
        (collectionName == 'attendance' && isTeacher()) ||
        (collectionName == 'exam_records' && isTeacher()) ||
        ((collectionName == 'expenditure_vouchers' || collectionName == 'transactions') && isAccountant())
      );

      allow delete: if signedIn() && (
        isSuperAdmin() || 
        (belongsToUserTenant(resource.data) && (isOwner() || isAdmin()))
      );
    }

    // Specific Parent Portal Privacy
    match /students/{studentId} {
      allow read: if signedIn() && (
        isSuperAdmin() || 
        belongsToUserTenant(resource.data) || 
        (isParent() && resource.data.parentUid == request.auth.uid)
      );
    }

    match /exam_records/{examId} {
      allow read: if signedIn() && (
        isSuperAdmin() || 
        belongsToUserTenant(resource.data) || 
        (isParent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentUid == request.auth.uid)
      );
    }
  }
}
