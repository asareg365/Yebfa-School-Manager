rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================
    // AUTH HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      // Role-based check from user profile
      return signedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "super_admin";
    }

    // ======================
    // USERS & PROFILES
    // ======================

    match /users/{userId} {
      allow read, write:
      if signedIn()
      &&
      (
        request.auth.uid == userId
        ||
        isSuperAdmin()
      );
    }

    // ======================
    // INSTITUTIONS & CONFIG
    // ======================

    match /institutions/{institutionId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete:
      if signedIn()
      &&
      (
        isSuperAdmin()
        ||
        resource.data.ownerUid == request.auth.uid
      );
    }

    match /settings/{settingId} {
      allow create, read, write:
      if signedIn();
    }

    match /departments/{departmentId} {
      allow create, read, write:
      if signedIn();
    }

    // ======================
    // MULTI-TENANT SCHOOL DATA
    // ======================

    // These rules allow general signed-in access for the MVP.
    // In production, these should strictly check request.auth.token.tenantId == resource.data.tenantId

    match /students/{studentId} {
      allow read, write: if signedIn();
    }

    match /staff/{staffId} {
      allow read, write: if signedIn();
    }

    match /subjects/{subjectId} {
      allow read, write: if signedIn();
    }

    match /exam_records/{recordId} {
      allow read, write: if signedIn();
    }

    match /attendance/{attendanceId} {
      allow read, write: if signedIn();
    }

    match /approved_fees/{feeId} {
      allow read, write: if signedIn();
    }

    match /student_ledger/{ledgerId} {
      allow read, write: if signedIn();
    }

    match /expenditure_vouchers/{voucherId} {
      allow read, write: if signedIn();
    }

    match /payroll_cycles/{cycleId} {
      allow read, write: if signedIn();
    }

    // SUPER ADMIN FALLBACK
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
