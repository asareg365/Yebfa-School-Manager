rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- AUTHENTICATION HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserEmail() {
      // Robust retrieval of user email from token
      let email = request.auth.token.email != null 
        ? request.auth.token.email 
        : request.auth.token.get('firebase', {}).get('identities', {}).get('email', [''])[0];
      return string(email).lower();
    }

    function isSuperAdmin() {
      let email = getUserEmail();
      // Explicitly authorized system administrators
      let admins = ['asareg365@gmail.com', 'frankyeb@gmail.com'];
      return isAuthenticated() && (email in admins);
    }

    function isOwner(resourceData) {
      // Safely check if the authenticated user matches the document ownerEmail
      let owner = resourceData.get('ownerEmail', '').lower();
      return isAuthenticated() && (owner == getUserEmail());
    }

    // --- GLOBAL OVERRIDE ---
    
    // Grant full access to identified Super Admins across all collections
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTION SPECIFIC RULES ---

    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /institutions/{institutionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Allow update if Super Admin OR the verified owner of the document
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || isOwner(resource.data));
    }

    match /students/{studentId} {
      allow read, write: if isAuthenticated();
    }

    match /staff/{staffId} {
      allow read, write: if isAuthenticated();
    }

    match /subjects/{subjectId} {
      allow read, write: if isAuthenticated();
    }

    match /exam_records/{recordId} {
      allow read, write: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read, write: if isAuthenticated();
    }

    match /approved_fees/{feeId} {
      allow read, write: if isAuthenticated();
    }

    match /student_ledger/{ledgerId} {
      allow read, write: if isAuthenticated();
    }
    
    match /expenditure_vouchers/{voucherId} {
      allow read, write: if isAuthenticated();
    }
    
    match /payroll_cycles/{cycleId} {
      allow read, write: if isAuthenticated();
    }
  }
}