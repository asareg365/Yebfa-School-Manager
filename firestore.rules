rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- AUTHENTICATION HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function getUserEmail() {
      // Direct accessor for maximum reliability as requested
      return request.auth.token.email.lower();
    }

    function isSuperAdmin() {
      let email = getUserEmail();
      // Explicitly authorized system administrators
      let admins = ['asareg365@gmail.com', 'frankyeb@gmail.com'];
      return isAuthenticated() && (email in admins);
    }

    // --- GLOBAL OVERRIDE ---
    
    // Grant unconditional access to identified Super Admins
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- COLLECTION SPECIFIC RULES ---

    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    // TEMPORARY PERMISSIVE RULE FOR INSTITUTION UPDATES
    match /institutions/{institutionId} {
      allow read: if true;
      allow update: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /students/{studentId} {
      allow read, write: if isAuthenticated();
    }

    match /staff/{staffId} {
      allow read, write: if isAuthenticated();
    }

    match /subjects/{subjectId} {
      allow read, write: if isAuthenticated();
    }

    match /exam_records/{recordId} {
      allow read, write: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read, write: if isAuthenticated();
    }

    match /approved_fees/{feeId} {
      allow read, write: if isAuthenticated();
    }

    match /student_ledger/{ledgerId} {
      allow read, write: if isAuthenticated();
    }
    
    match /expenditure_vouchers/{voucherId} {
      allow read, write: if isAuthenticated();
    }
    
    match /payroll_cycles/{cycleId} {
      allow read, write: if isAuthenticated();
    }
  }
}