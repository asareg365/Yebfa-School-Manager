rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null && (request.auth.token.email == 'asareg365@gmail.com' || request.auth.token.email == 'frankyeb@gmail.com');
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    match /institutions/{institutionId} {
      allow read: if request.auth != null;
      // Allow create if super admin or if the user being assigned as owner matches the logged in user
      allow create: if request.auth != null && (isSuperAdmin() || request.resource.data.ownerEmail == request.auth.token.email);
      allow update, delete: if request.auth != null && (isSuperAdmin() || resource.data.ownerEmail == request.auth.token.email);
    }

    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }

    match /staff/{staffId} {
      allow read, write: if request.auth != null;
    }
  }
}