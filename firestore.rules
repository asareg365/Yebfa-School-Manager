
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================
    // AUTH & PROFILE HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userTenant() {
      return hasProfile() ? userProfile().tenantId : "NONE";
    }

    function userRole() {
      return hasProfile() ? userProfile().role : "GUEST";
    }

    // ======================
    // ROLE DEFINITIONS
    // ======================
    
    function isSuperAdmin() { return signedIn() && userRole() == "super_admin"; }
    function isOwner() { return signedIn() && userRole() == "school_owner"; }
    function isAdmin() { return signedIn() && userRole() == "administrator"; }
    function isAccountant() { return signedIn() && userRole() == "accountant"; }
    function isTeacher() { return signedIn() && userRole() == "teacher"; }
    function isParent() { return signedIn() && userRole() == "parent"; }
    function isLibrarian() { return signedIn() && userRole() == "librarian"; }
    
    // ======================
    // TENANT ISOLATION LOGIC
    // ======================

    function belongsToUserTenant(data) {
      return signedIn() && data.tenantId == userTenant();
    }

    function isValidTenantLock() {
      return signedIn() && (
        isSuperAdmin() || 
        (request.resource.data.tenantId == userTenant() && 
        (resource == null || request.resource.data.tenantId == resource.data.tenantId))
      );
    }

    // ======================
    // COLLECTION RULES
    // ======================

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isSuperAdmin() || belongsToUserTenant(resource.data));
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /institutions/{instId} {
      allow read: if signedIn() && (isSuperAdmin() || instId == userTenant());
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSuperAdmin() || (signedIn() && instId == userTenant() && (isOwner() || isAdmin()));
    }

    match /parents/{parentId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToUserTenant(resource.data));
      allow create, update: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin() || isAccountant());
      allow delete: if isSuperAdmin() || isOwner();
    }

    match /students/{studentId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToUserTenant(resource.data));
      allow create, update: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin() || isTeacher());
      allow delete: if isSuperAdmin() || isOwner();
    }

    match /staff/{staffId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToUserTenant(resource.data));
      allow create, update: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin() || isAccountant());
      allow delete: if isSuperAdmin() || isOwner();
    }

    // Standard Multi-Tenant Rule Pattern for other modules
    match /{collectionName}/{docId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToUserTenant(resource.data));
      allow create, update: if signedIn() && (isSuperAdmin() || belongsToUserTenant(request.resource.data));
      allow delete: if signedIn() && (isSuperAdmin() || (belongsToUserTenant(resource.data) && (isOwner() || isAdmin())));
    }
  }
}
