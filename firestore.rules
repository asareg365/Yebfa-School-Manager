rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {


    // -----------------------------
    // AUTHENTICATION HELPERS
    // -----------------------------

    function signedIn() {
      return request.auth != null;
    }


    function userEmail() {
      return request.auth.token.email;
    }


    function isSuperAdmin() {
      return signedIn() &&
      (
        userEmail() == "asareg365@gmail.com" ||
        userEmail() == "frankyeb@gmail.com"
      );
    }


    function ownsInstitution() {
      return resource.data.ownerEmail == userEmail();
    }


    // -----------------------------
    // INSTITUTIONS
    // -----------------------------

    match /institutions/{institutionId} {

      allow read: if signedIn();

      allow create: if signedIn();

      allow update, delete:
      if signedIn()
      &&
      (
        isSuperAdmin()
        ||
        ownsInstitution()
      );
    }



    // -----------------------------
    // USERS
    // -----------------------------

    match /users/{userId} {

      allow read, write:
      if signedIn()
      &&
      (
        request.auth.uid == userId
        ||
        isSuperAdmin()
      );
    }



    // -----------------------------
    // SCHOOL DATA
    // -----------------------------

    match /students/{studentId} {

      allow read, write:
      if signedIn();
    }


    match /staff/{staffId} {

      allow read, write:
      if signedIn();
    }


    match /subjects/{subjectId} {

      allow read, write:
      if signedIn();
    }


    match /exam_records/{recordId} {

      allow read, write:
      if signedIn();
    }


    match /attendance/{attendanceId} {

      allow read, write:
      if signedIn();
    }


    match /approved_fees/{feeId} {

      allow read, write:
      if signedIn();
    }


    match /student_ledger/{ledgerId} {

      allow read, write:
      if signedIn();
    }


    match /expenditure_vouchers/{voucherId} {

      allow read, write:
      if signedIn();
    }


    match /payroll_cycles/{cycleId} {

      allow read, write:
      if signedIn();
    }



    // -----------------------------
    // SUPER ADMIN OVERRIDE
    // -----------------------------

    match /{document=**} {

      allow read, write:
      if isSuperAdmin();
    }

  }
}