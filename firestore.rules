
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================
    // AUTH HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userTenant() {
      return userProfile().tenantId;
    }

    function userRole() {
      return userProfile().role;
    }

    // ROLE DEFINITIONS
    function isSuperAdmin() { return signedIn() && userRole() == "super_admin"; }
    function isOwner() { return signedIn() && userRole() == "school_owner"; }
    function isAdmin() { return signedIn() && userRole() == "administrator"; }
    function isAccountant() { return signedIn() && userRole() == "accountant"; }
    function isTeacher() { return signedIn() && userRole() == "teacher"; }
    function isParent() { return signedIn() && userRole() == "parent"; }
    function isLibrarian() { return signedIn() && userRole() == "librarian"; }
    
    function belongsToTenant(data) {
      return data.tenantId == userTenant();
    }

    // ======================
    // SECURITY RULES
    // ======================

    match /users/{userId} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /institutions/{instId} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner());
    }

    // ACADEMIC FOUNDATION
    match /academic_years/{id} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin());
    }

    match /terms/{id} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin());
    }

    match /classes/{id} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin());
    }

    match /sections/{id} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin());
    }

    match /subjects/{id} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin());
    }

    match /teacher_assignments/{id} {
      allow read: if signedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow write: if signedIn() && (isSuperAdmin() || isOwner() || isAdmin());
    }

    // CATCH ALL
    match /{document=**} {
      allow read: if signedIn() && (isSuperAdmin() || (resource.data != null && belongsToTenant(resource.data)));
      allow write: if signedIn() && (isSuperAdmin() || (request.resource.data != null && belongsToTenant(request.resource.data) && (isOwner() || isAdmin())));
    }
  }
}
