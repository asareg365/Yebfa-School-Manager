rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================
    // AUTH HELPERS
    // ======================

    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userTenant() {
      return userProfile().tenantId;
    }

    function userRole() {
      return userProfile().role;
    }

    function isSuperAdmin() {
      return signedIn() && userRole() == "super_admin";
    }

    // ======================
    // USERS & PROFILES
    // ======================

    match /users/{userId} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // ======================
    // INSTITUTIONS & CONFIG
    // ======================

    match /institutions/{institutionId} {
      allow create: if signedIn();
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || (resource.data.tenantId == userTenant() && userRole() == "school_owner"));
    }

    match /settings/{settingId} {
      allow create: if signedIn();
      allow read, write: if signedIn() && (isSuperAdmin() || settingId == userTenant() || resource.data.tenantId == userTenant());
    }

    match /departments/{departmentId} {
      allow create: if signedIn();
      allow read, write: if signedIn() && (isSuperAdmin() || departmentId == userTenant() || resource.data.tenantId == userTenant());
    }

    // ======================
    // MULTI-TENANT SCHOOL DATA
    // ======================

    match /students/{studentId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /staff/{staffId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /subjects/{subjectId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /exam_records/{recordId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /attendance/{attendanceId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /approved_fees/{feeId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /student_ledger/{ledgerId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /expenditure_vouchers/{voucherId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    match /payroll_cycles/{cycleId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
      allow create: if signedIn() && (isSuperAdmin() || request.resource.data.tenantId == userTenant());
      allow update, delete: if signedIn() && (isSuperAdmin() || resource.data.tenantId == userTenant());
    }

    // SUPER ADMIN FALLBACK
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}